# Copy this file to .env and fill in the values you need.
# `docker compose up` reads .env automatically.

# At least one of these is required (whichever provider you run against).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Path to the project you want Gauntlet to test. Compose mounts
# $TARGET_PROJECT into the container as /project; Gauntlet writes its
# state under /project/.gauntlet/. Leave unset (or set to ".") for
# Gauntlet-on-Gauntlet.
# TARGET_PROJECT=/Users/you/Code/my-app

# Optional overrides.
# Host+container port for the Gauntlet server. Set this if you're running
# multiple Gauntlets side-by-side (e.g. green on 4401, blue on 4400).
# GAUNTLET_PORT=4400
# GAUNTLET_AGENT_MODEL=claude-sonnet-4-6
# GAUNTLET_FANOUT_MODEL=claude-sonnet-4-6

# Maximum time (ms) `gauntlet serve` waits for in-flight runs to complete
# after receiving SIGTERM/SIGINT/SIGHUP before forcing exit. Set higher
# (e.g. 60000) if your typical run is longer than 10s and you want clean
# shutdown to wait for runs to finish naturally.
# GAUNTLET_SHUTDOWN_GRACE_MS=10000

# Server input caps (PRI-1478). All four refuse oversized requests with
# structured 4xx errors; raise them only if you know what you're doing.
# Body cap (bytes) — POST larger than this returns 413 body_too_large.
# GAUNTLET_MAX_REQUEST_BODY_SIZE=1048576
# In-flight run ceiling — extra POSTs return 429 too_many_runs.
# GAUNTLET_MAX_CONCURRENT_RUNS=4
# Hard upper bound on body.turns — exceeds returns 400 turns_too_high.
# GAUNTLET_MAX_TURNS_CAP=200
# Active-runs list view truncates target field beyond this many bytes.
# Per-run snapshot endpoint still returns the full target.
# GAUNTLET_ACTIVE_RUN_TARGET_MAX_BYTES=1024

# WebSocket hygiene (PRI-1483).
# Idle timeout in seconds — Bun closes WS connections that have been
# silent for this long. Defends against accumulating dead subscribers.
# GAUNTLET_WS_IDLE_TIMEOUT_SEC=60
# Comma-separated list of allowed Origin header values for WS upgrades.
# When unset, no Origin check is performed. Defense-in-depth, opt-in.
# GAUNTLET_WS_ORIGIN_ALLOWLIST=http://localhost:4400,https://your.domain
