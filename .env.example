# Copy this file to .env and fill in the values you need.
# `docker compose up` reads .env automatically.

# At least one of these is required (whichever provider you run against).
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Path to the project you want Gauntlet to test. Compose mounts
# $TARGET_PROJECT/.gauntlet into the container as the data directory.
# Leave unset (or set to ".") for Gauntlet-on-Gauntlet.
# TARGET_PROJECT=/Users/you/Code/my-app

# Optional overrides.
# Host+container port for the Gauntlet server. Set this if you're running
# multiple Gauntlets side-by-side (e.g. green on 4401, blue on 4400).
# GAUNTLET_PORT=4400
# GAUNTLET_AGENT_MODEL=claude-sonnet-4-20250514
# GAUNTLET_FANOUT_MODEL=claude-sonnet-4-20250514
