{
  "name": "gauntlet",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "bin": {
    "gauntlet": "src/index.ts"
  },
  "scripts": {
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "typecheck:ui": "tsc -p ui/tsconfig.json --noEmit",
    "build:ui": "cd ui && bun run build && bun run build:static",
    "test": "bun test",
    "check": "bun run typecheck && bun run typecheck:ui && bun run build:ui && bun run test",
    "install-hooks": "bash scripts/install-hooks.sh",
    "prepare": "bash scripts/install-hooks.sh"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/node": "^25.3.5",
    "@types/react": "^19.2.14",
    "@types/ws": "^8.18.1",
    "bun-types": "^1.3.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "engines": {
    "bun": ">=1.3.14"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@aws-sdk/client-bedrock-runtime": "^3.1071.0",
    "@aws-sdk/credential-providers": "^3.1071.0",
    "@hono/node-server": "^2.0.1",
    "@xterm/headless": "^6.0.0",
    "hono": "^4.12.5",
    "ink": "^7.0.3",
    "openai": "^6.27.0",
    "react": "^19.2.6",
    "ws": "^8.20.0",
    "yaml": "^2.8.3"
  }
}
